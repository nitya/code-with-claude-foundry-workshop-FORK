{
  "name": "Python with Azure CLI & Docker",
  "image": "mcr.microsoft.com/devcontainers/python:3.12",
  "features": {
    "ghcr.io/devcontainers/features/azure-cli:1": {}
  },

  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python",
        "ms-vscode.azurecli",
        "GitHub.copilot",
        "GitHub.copilot-chat",
        "ms-toolsai.jupyter",
        "ms-windows-ai-studio.windows-ai-studio"
      ]
    }
  },
 
  "postCreateCommand": "pip install -r sandbox/requirements.txt"
  

} 